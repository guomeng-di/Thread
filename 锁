void amountInit(lock_t* Account) {//初始化 lock_t 结构
  Account->amount=0;
  pthread_mutex_init(&Account->mutex,NULL);
  
}

void Income(lock_t* Account, int amount) { //用于进行资金收入操作，金额为 amount
  pthread_mutex_lock(&Account->mutex);//加锁
  Account->amount+=amount;
  pthread_mutex_unlock(&Account->mutex);//解锁
}

void Expend(lock_t* Account, int amount) {//用于进行资金支出操作，金额为 amount
  pthread_mutex_lock(&Account->mutex);
  Account->amount-=amount;
  pthread_mutex_unlock(&Account->mutex);
}

